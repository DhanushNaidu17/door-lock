    resetMode = true;
    input = "";
    modeTimer = millis();

    Serial.println("\n🔄 RESET PASSWORD MODE (HOLD)");
    Serial.println("Enter admin key:");
  }

  // 🔐 ENROLL MODE (HOLD *)
  if (state == HOLD && key == '*') {

    enrollMode = true;
    adminInput = "";
    modeTimer = millis();

    Serial.println("\n🔐 ADD NEW OWNER MODE (HOLD)");
    Serial.println("Enter admin key:");
  }
}
