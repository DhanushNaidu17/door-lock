// ================= EEPROM =================
void savePassword(String pass) {
  for (int i = 0; i < 6; i++) EEPROM.write(i, pass[i]);
  EEPROM.commit();
}

String readPassword() {
  String pass = "";
  for (int i = 0; i < 6; i++) pass += char(EEPROM.read(i));
  return pass;
}

